# 🔐 SANDBOX PERMISSIONS & SECURITY
ALLOW_NETWORK_DEFAULT=true
ALLOW_DEPENDENCY_INSTALL=true
ALLOW_ROOT_DEP_INSTALL=true
CONTAINER_AUTO_REMOVE=true
CONTAINER_READ_ONLY_ROOT=false
CONTAINER_CAP_DROP=["ALL"]
CONTAINER_SECURITY_OPT=["no-new-privileges"]
DISABLE_IPV6=true
CONTAINER_DNS=["8.8.8.8", "1.1.1.1"]
SANDBOX_USER=1000:1000

# ⚡ RESOURCE & EXECUTION LIMITS
MEM_LIMIT=512m
CPU_QUOTA=50000
TMPFS_SIZE=500m
EXEC_TIMEOUT=600
DEP_INSTALL_TIMEOUT=300
MAX_RETRIES=3

# 🤖 AGENT & CONTEXT LIMITS
MAX_CHAT_HISTORY=8
ENABLE_OLLAMA_VRAM_CLEANUP=true

# 📂 PATHS & LOGGING
WORKSPACE_BASE=sandbox_workspace
OUTPUT_DIR=outputs
LOG_DIR=logs
LOG_LEVEL=INFO
REDACT_SECRETS_IN_LOGS=true

# 🔑 PROVIDER CREDENTIALS
OLLAMA_BASE_URL=http://localhost:11434
OPENAI_BASE_URL=
GOOGLE_API_KEY=
OPENAI_API_KEY=
BYOK_API_KEY=
BYOK_BASE_URL=
OLLAMA_CLOUD_API_KEY=
OLLAMA_CLOUD_BASE_URL=https://api.ollama.com/v1
SESSION_TIME_BUDGET_MINUTES=30
ALLOWED_CUSTOM_IMAGES=["python","node","golang","jupyter/base-notebook"]
ENABLE_PERSISTENT_SANDBOXES=True
MAX_ACTIVE_SESSIONS=5
